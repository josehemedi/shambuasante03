# Variables injectées au BUILD (Vite bake-in)
# Avec Docker : passer via --build-arg (voir Dockerfile / docker-compose)
#
# En prod derrière nginx (recommandé) : chemins relatifs + reverse-proxy
VITE_API_BASE_URL=/api
VITE_WS_URL=
VITE_USE_LIVE_API=true

# Si le frontend et l’API sont sur des domaines séparés (sans reverse-proxy) :
# VITE_API_BASE_URL=https://api.votredomaine.com/api
# VITE_WS_URL=https://api.votredomaine.com
