# Développement local (Vite proxy → backend 8082)
# Copier vers .env : cp .env.example .env

VITE_API_BASE_URL=/api

# HTTPS dev (caméra/micro mobile via IP) : VITE_DEV_HTTPS=true
# VITE_DEV_HTTPS=false

# Laisser vide pour utiliser le proxy Vite (/ws)
# VITE_WS_URL=

# true = API réelle | false = mocks
VITE_USE_LIVE_API=true
